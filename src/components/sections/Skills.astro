---
// Skills component: render a flat list of strings as badges.
// Supports both string entries and objects with a `name` field.
const items = Astro.props.items ?? [];

function renderSkill(item) {
  if (typeof item === 'string') return item;
  if (typeof item === 'object' && item !== null) return item.name ?? '';
  return '';
}
---

<style>
  .skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 0.5rem; }
  .badge { background: #e5e7eb; color: #111827; padding: 0.25rem 0.6rem; border-radius: 0.375rem; font-size: 0.875rem; display: inline-block; }
</style>

<div class="skills-grid">
  {items.map((it) => (
    <span class="badge">{renderSkill(it)}</span>
  ))}
</div>
