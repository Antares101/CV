---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';
import AnimatedSection from '../../islands/AnimatedSection';
import SkillBars from '../../islands/SkillBars';
import Persona5Card from '../ui/Persona5Card.astro';

interface SkillItem {
  name: string;
  level: number;
}

interface SkillCategory {
  category: string;
  items: SkillItem[];
}

export interface Props {
  locale: Locale;
  categories: SkillCategory[];
}

const { locale, categories } = Astro.props;
const t = useTranslations(locale);
---

<section id="skills" class="relative py-24 sm:py-32 bg-p5-dark scroll-mt-16 overflow-hidden">
  <div class="p5-shard-corner-tl" aria-hidden="true"></div>
  <div class="p5-shard-corner-br" aria-hidden="true"></div>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <AnimatedSection client:visible>
      <h2 class="font-display text-4xl sm:text-5xl uppercase tracking-wider text-p5-white mb-2">
        {t('section.skills')}
      </h2>
      <div class="p5-section-divider mb-12"></div>
    </AnimatedSection>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {categories.map((category) => (
        <AnimatedSection client:visible>
          <Persona5Card>
            <h3 class="font-bold text-p5-white mb-6 flex items-center gap-2 uppercase text-sm tracking-wider p5-hover-skew">
              <span class="w-2 h-2 bg-p5-red"></span>
              {category.category}
            </h3>

            <SkillBars skills={category.items} />
          </Persona5Card>
        </AnimatedSection>
      ))}
    </div>
  </div>
</section>
