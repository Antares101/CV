---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';
import AnimatedSection from '../../islands/AnimatedSection';
import Persona5Card from '../ui/Persona5Card.astro';

interface ExperienceItem {
  role: string;
  company: string;
  period: string;
  description: string;
  highlights: string[];
}

export interface Props {
  locale: Locale;
  items: ExperienceItem[];
}

const { locale, items } = Astro.props;
const t = useTranslations(locale);
---

<section id="experience" class="relative py-24 sm:py-32 bg-p5-black scroll-mt-16 overflow-hidden">
  <div class="p5-shard-corner-tl" aria-hidden="true"></div>
  <div class="p5-shard-corner-br" aria-hidden="true"></div>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <AnimatedSection client:visible>
      <h2 class="font-display text-4xl sm:text-5xl uppercase tracking-wider text-p5-white mb-2">
        {t('section.experience')}
      </h2>
      <div class="p5-section-divider mb-12"></div>
    </AnimatedSection>

    <div class="relative">
      <!-- P5 Timeline line -->
      <div class="absolute left-0 md:left-8 top-0 bottom-0 w-0.5 bg-p5-red/30" aria-hidden="true"></div>

      <div class="space-y-12">
        {items.map((item) => (
          <AnimatedSection client:visible>
            <div class="relative pl-8 md:pl-20">
              <!-- P5 Timeline dot -->
              <div class="absolute left-0 md:left-8 top-1 w-3.5 h-3.5 -translate-x-[7px] rounded-full bg-p5-red border-[3px] border-p5-black shadow-[0_0_8px_rgba(229,57,53,0.5)]" aria-hidden="true"></div>

              <!-- P5 Card -->
              <Persona5Card>
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-3 gap-1">
                  <h3 class="text-xl font-bold text-p5-white p5-hover-skew">
                    {item.role}
                    <span class="text-p5-red"> · {item.company}</span>
                  </h3>
                  <span class="text-sm font-mono text-p5-muted whitespace-nowrap">
                    {item.period}
                  </span>
                </div>

                <p class="text-p5-muted mb-4 leading-relaxed">
                  {item.description}
                </p>

                {item.highlights && item.highlights.length > 0 && (
                  <ul class="space-y-2">
                    {item.highlights.map((highlight) => (
                      <li class="flex items-start gap-2 text-sm text-p5-muted">
                        <svg class="w-4 h-4 mt-0.5 text-p5-red shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span>{highlight}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </Persona5Card>
            </div>
          </AnimatedSection>
        ))}
      </div>
    </div>
  </div>
</section>
