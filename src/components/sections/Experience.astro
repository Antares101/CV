---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';
import AnimatedSection from '../../islands/AnimatedSection';

interface ExperienceItem {
  role: string;
  company: string;
  period: string;
  description: string;
  highlights: string[];
}

export interface Props {
  locale: Locale;
  items: ExperienceItem[];
}

const { locale, items } = Astro.props;
const t = useTranslations(locale);
---

<section id="experience" class="py-24 sm:py-32">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <AnimatedSection client:visible>
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        <span class="bg-gradient-to-r from-accent-400 to-blue-500 bg-clip-text text-transparent">
          {t('section.experience')}
        </span>
      </h2>
      <div class="w-20 h-1 bg-accent-400 rounded-full mb-12"></div>
    </AnimatedSection>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-0 md:left-8 top-0 bottom-0 w-px bg-gray-200 dark:bg-gray-800" aria-hidden="true"></div>

      <div class="space-y-12">
        {items.map((item) => (
          <AnimatedSection client:visible>
            <div class="relative pl-8 md:pl-20">
              <!-- Timeline dot -->
              <div class="absolute left-0 md:left-8 top-1 w-3 h-3 -translate-x-1/2 rounded-full bg-accent-400 border-2 border-white dark:border-slate-950 shadow-sm" aria-hidden="true"></div>

              <!-- Card -->
              <div class="group p-6 rounded-2xl bg-gray-50 dark:bg-gray-900/50 border border-gray-200 dark:border-gray-800 hover:border-accent-300 dark:hover:border-accent-700 hover:shadow-lg transition-all duration-300">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-3 gap-1">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white">
                    {item.role}
                    <span class="text-accent-500"> · {item.company}</span>
                  </h3>
                  <span class="text-sm font-mono text-gray-500 dark:text-gray-500 whitespace-nowrap">
                    {item.period}
                  </span>
                </div>

                <p class="text-gray-600 dark:text-gray-400 mb-4 leading-relaxed">
                  {item.description}
                </p>

                {item.highlights && item.highlights.length > 0 && (
                  <ul class="space-y-2">
                    {item.highlights.map((highlight) => (
                      <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                        <svg class="w-4 h-4 mt-0.5 text-accent-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span>{highlight}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          </AnimatedSection>
        ))}
      </div>
    </div>
  </div>
</section>
