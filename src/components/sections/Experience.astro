---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';
import AnimatedSection from '../../islands/AnimatedSection';
import Persona5Card from '../ui/Persona5Card.astro';

interface ExperienceItem {
  role: string;
  company: string;
  period: string;
  description: string;
  highlights: string[];
}

export interface Props {
  locale: Locale;
  items: ExperienceItem[];
}

const { locale, items } = Astro.props;
const t = useTranslations(locale);
---

<section id="experience" class="relative py-24 sm:py-32 bg-p5-black scroll-mt-16 overflow-hidden p5-stripe-bg">
  <!-- Decorative elements -->
  <div class="p5-shard-corner-tl" aria-hidden="true"></div>
  <div class="p5-shard-corner-br" aria-hidden="true"></div>
  <div class="p5-corner-accent-tl" aria-hidden="true"></div>
  <div class="p5-corner-accent-br" aria-hidden="true"></div>

  <!-- Diagonal accent lines -->
  <div class="absolute top-1/4 -right-20 w-40 h-[2px] bg-p5-red/10 rotate-[-35deg]" aria-hidden="true"></div>
  <div class="absolute bottom-1/3 -left-20 w-40 h-[2px] bg-p5-red/10 rotate-[-35deg]" aria-hidden="true"></div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <AnimatedSection client:visible>
      <h2 class="font-display text-4xl sm:text-5xl uppercase tracking-wider text-p5-white mb-2 p5-section-header">
        {t('section.experience')}
      </h2>
      <div class="p5-section-divider-enhanced mb-12"></div>
    </AnimatedSection>

    <div class="relative">
      <!-- P5 Timeline line - more dramatic -->
      <div class="absolute left-0 md:left-8 top-0 bottom-0 w-[3px] bg-gradient-to-b from-p5-red via-p5-red/50 to-p5-red/10" aria-hidden="true"></div>

      <div class="space-y-16">
        {items.map((item) => (
          <AnimatedSection client:visible>
            <div class="relative pl-8 md:pl-20">
              <!-- P5 Timeline dot - diamond shape -->
              <div class="absolute left-0 md:left-8 top-1 p5-timeline-dot-enhanced -translate-x-[8px]" aria-hidden="true"></div>

              <!-- P5 Card - enhanced -->
              <Persona5Card class="p5-card-aggressive">
                <div class="p-6">
                  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-3 gap-1">
                    <h3 class="text-xl font-bold text-p5-white">
                      {item.role}
                      <span class="text-p5-red"> · {item.company}</span>
                    </h3>
                    <span class="text-sm font-mono text-p5-muted whitespace-nowrap p5-tag">
                      {item.period}
                    </span>
                  </div>

                  <p class="text-p5-muted mb-4 leading-relaxed">
                    {item.description}
                  </p>

                  {item.highlights && item.highlights.length > 0 && (
                    <ul class="space-y-2">
                      {item.highlights.map((highlight) => (
                        <li class="flex items-start gap-2 text-sm text-p5-muted">
                          <svg class="w-4 h-4 mt-0.5 text-p5-red shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                          </svg>
                          <span>{highlight}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </Persona5Card>
            </div>
          </AnimatedSection>
        ))}
      </div>
    </div>
  </div>
</section>