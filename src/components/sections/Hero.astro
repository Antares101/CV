---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';

interface Social {
  github?: string;
  linkedin?: string;
  twitter?: string;
  website?: string;
}

export interface Props {
  locale: Locale;
  name: string;
  headline: string;
  about: string;
  location: string;
  social: Social;
}

const { locale, name, headline, about, location, social } = Astro.props;
const t = useTranslations(locale);
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background gradient decoration -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent-400/10 dark:bg-accent-400/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-400/10 dark:bg-purple-400/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <!-- Name with gradient -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tight mb-4 animate-fade-in-down">
      <span class="bg-gradient-to-r from-accent-400 via-blue-500 to-purple-600 bg-clip-text text-transparent">
        {name}
      </span>
    </h1>

    <!-- Headline -->
    <p class="text-xl sm:text-2xl text-gray-600 dark:text-gray-400 font-medium mb-6 animate-fade-in-up" style="animation-delay: 200ms">
      {headline}
    </p>

    <!-- Location -->
    <p class="text-sm text-gray-500 dark:text-gray-500 mb-8 animate-fade-in" style="animation-delay: 400ms">
      <svg class="inline-block w-4 h-4 mr-1 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      {location}
    </p>

    <!-- About -->
    <p class="max-w-2xl mx-auto text-base sm:text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-10 animate-fade-in-up" style="animation-delay: 400ms">
      {about}
    </p>

    <!-- Social links -->
    <div class="flex items-center justify-center gap-4 animate-fade-in-up" style="animation-delay: 600ms">
      {social.github && (
        <a href={social.github} target="_blank" rel="noopener noreferrer" class="group p-3 rounded-xl bg-gray-100 dark:bg-gray-800 hover:bg-accent-100 dark:hover:bg-accent-950 hover:text-accent-500 transition-all duration-300" aria-label="GitHub">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        </a>
      )}
      {social.linkedin && (
        <a href={social.linkedin} target="_blank" rel="noopener noreferrer" class="group p-3 rounded-xl bg-gray-100 dark:bg-gray-800 hover:bg-accent-100 dark:hover:bg-accent-950 hover:text-accent-500 transition-all duration-300" aria-label="LinkedIn">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      )}
      {social.twitter && (
        <a href={social.twitter} target="_blank" rel="noopener noreferrer" class="group p-3 rounded-xl bg-gray-100 dark:bg-gray-800 hover:bg-accent-100 dark:hover:bg-accent-950 hover:text-accent-500 transition-all duration-300" aria-label="Twitter">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      )}
      {social.website && (
        <a href={social.website} target="_blank" rel="noopener noreferrer" class="group p-3 rounded-xl bg-gray-100 dark:bg-gray-800 hover:bg-accent-100 dark:hover:bg-accent-950 hover:text-accent-500 transition-all duration-300" aria-label="Website">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
        </a>
      )}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-fade-in" style="animation-delay: 1s">
    <p class="text-xs text-gray-400 dark:text-gray-600 mb-2 tracking-widest uppercase">{t('hero.scroll')}</p>
    <div class="flex justify-center">
      <svg class="w-5 h-5 text-gray-400 dark:text-gray-600 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>
