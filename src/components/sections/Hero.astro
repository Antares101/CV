---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';

interface Social {
  github?: string;
  linkedin?: string;
  twitter?: string;
  website?: string;
}

export interface Props {
  locale: Locale;
  name: string;
  headline: string;
  about: string;
  location: string;
  social: Social;
}

const { locale, name, headline, about, location, social } = Astro.props;
const t = useTranslations(locale);
const nameParts = name.split(' ');
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-p5-black">
  <!-- P5 Shard decorations — more dramatic -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <!-- Noise texture overlay -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 128px;"></div>

    <!-- Angular shards — more of them, bigger -->
    <div class="absolute top-16 left-8 w-0 h-0 border-l-[35px] border-r-[35px] border-b-[60px] border-l-transparent border-r-transparent border-b-p5-red/20 animate-p5-shard"></div>
    <div class="absolute top-1/3 right-16 w-0 h-0 border-l-[25px] border-r-[25px] border-t-[43px] border-l-transparent border-r-transparent border-t-p5-red/15 animate-p5-shard" style="animation-delay: 300ms"></div>
    <div class="absolute bottom-1/4 left-1/4 w-0 h-0 border-l-[30px] border-r-[30px] border-b-[52px] border-l-transparent border-r-transparent border-b-p5-red/10 animate-p5-shard" style="animation-delay: 600ms"></div>
    <div class="absolute top-1/2 right-1/3 w-0 h-0 border-l-[18px] border-r-[18px] border-t-[31px] border-l-transparent border-r-transparent border-t-p5-red/10 p5-float-shard"></div>
    <div class="absolute bottom-1/3 left-1/3 w-0 h-0 border-l-[14px] border-r-[14px] border-b-[24px] border-l-transparent border-r-transparent border-b-p5-red/10 p5-float-shard-delayed"></div>

    <!-- Additional floating shards -->
    <div class="absolute top-2/3 right-1/4 w-0 h-0 border-l-[10px] border-r-[10px] border-t-[17px] border-l-transparent border-r-transparent border-t-p5-red/8 p5-float-shard-enhanced"></div>
    <div class="absolute top-1/4 left-2/3 w-0 h-0 border-l-[12px] border-r-[12px] border-b-[21px] border-l-transparent border-r-transparent border-b-p5-red/8 p5-float-shard-enhanced-delayed"></div>

    <!-- Red diagonal accent lines — more dramatic -->
    <svg class="absolute top-0 right-0 w-80 h-full opacity-10" viewBox="0 0 100 800" preserveAspectRatio="none">
      <line x1="100" y1="0" x2="0" y2="800" stroke="#e53935" stroke-width="3" />
      <line x1="80" y1="0" x2="-20" y2="800" stroke="#e53935" stroke-width="1.5" />
      <line x1="60" y1="0" x2="-40" y2="800" stroke="#e53935" stroke-width="1" />
    </svg>
    <svg class="absolute bottom-0 left-0 w-80 h-full opacity-10" viewBox="0 0 100 800" preserveAspectRatio="none">
      <line x1="0" y1="0" x2="100" y2="800" stroke="#e53935" stroke-width="3" />
      <line x1="20" y1="0" x2="120" y2="800" stroke="#e53935" stroke-width="1.5" />
      <line x1="40" y1="0" x2="140" y2="800" stroke="#e53935" stroke-width="1" />
    </svg>

    <!-- Corner accent lines -->
    <div class="absolute top-0 left-0 w-24 h-[3px] bg-p5-red/30"></div>
    <div class="absolute top-0 left-0 h-24 w-[3px] bg-p5-red/30"></div>
    <div class="absolute bottom-0 right-0 w-24 h-[3px] bg-p5-red/30"></div>
    <div class="absolute bottom-0 right-0 h-24 w-[3px] bg-p5-red/30"></div>

    <!-- Subtle scanline overlay -->
    <div class="p5-scanline"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <!-- Name with P5 style — more dramatic -->
    <h1 class="font-display text-[clamp(3rem,8vw,7rem)] leading-none tracking-wider uppercase mb-4 animate-p5-skew-in p5-glitch-text" data-text={name}>
      {nameParts.length > 1 ? (
        <>
          <span class="text-p5-white p5-hover-skew">{nameParts.slice(0, -1).join(' ')}</span>
          <br />
          <span class="text-p5-red p5-hover-skew">{nameParts.slice(-1)}</span>
        </>
      ) : (
        <span class="text-p5-white">{name}</span>
      )}
    </h1>

    <!-- Red divider — angular -->
    <div class="w-24 h-1 bg-p5-red mx-auto mb-6 animate-p5-fade-in p5-angular-border-sm" style="animation-delay: 200ms"></div>

    <!-- Headline — with angular accent -->
    <p class="text-xl sm:text-2xl text-p5-muted font-medium mb-6 animate-p5-slide-up relative" style="animation-delay: 300ms">
      <span class="text-p5-red font-display mr-2">//</span>
      {headline}
    </p>

    <!-- Location -->
    <p class="text-sm font-mono text-p5-muted mb-8 animate-p5-fade-in" style="animation-delay: 500ms">
      <svg class="inline-block w-4 h-4 mr-1 -mt-0.5 text-p5-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      {location}
    </p>

    <!-- About -->
    <p class="max-w-2xl mx-auto text-base sm:text-lg text-p5-muted leading-relaxed mb-10 animate-p5-slide-up" style="animation-delay: 600ms">
      {about}
    </p>

    <!-- Social links — P5 angular style -->
    <div class="flex items-center justify-center gap-4 animate-p5-bounce-in" style="animation-delay: 800ms">
      {social.github && (
        <a href={social.github} target="_blank" rel="noopener noreferrer" class="p5-social-link" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        </a>
      )}
      {social.linkedin && (
        <a href={social.linkedin} target="_blank" rel="noopener noreferrer" class="p5-social-link" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      )}
      {social.twitter && (
        <a href={social.twitter} target="_blank" rel="noopener noreferrer" class="p5-social-link" aria-label="Twitter">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      )}
      {social.website && (
        <a href={social.website} target="_blank" rel="noopener noreferrer" class="p5-social-link" aria-label="Website">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
        </a>
      )}
    </div>

    <!-- Scroll indicator — P5 angular style -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-p5-pulse">
      <div class="flex flex-col items-center gap-2 text-p5-muted">
        <span class="text-xs font-mono uppercase tracking-widest">{t('hero.scroll')}</span>
        <svg class="w-5 h-5 text-p5-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>
  </div>
</section>