---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';
import AnimatedSection from '../../islands/AnimatedSection';
import Persona5Card from '../ui/Persona5Card.astro';

interface EducationItem {
  degree: string;
  institution: string;
  period: string;
  details?: string;
}

export interface Props {
  locale: Locale;
  items: EducationItem[];
}

const { locale, items } = Astro.props;
const t = useTranslations(locale);
---

<section id="education" class="relative py-24 sm:py-32 bg-p5-dark scroll-mt-16 overflow-hidden">
  <div class="p5-shard-corner-tl" aria-hidden="true"></div>
  <div class="p5-shard-corner-br" aria-hidden="true"></div>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <AnimatedSection client:visible>
      <h2 class="font-display text-4xl sm:text-5xl uppercase tracking-wider text-p5-white mb-2">
        {t('section.education')}
      </h2>
      <div class="p5-section-divider mb-12"></div>
    </AnimatedSection>

    <div class="space-y-6">
      {items.map((item) => (
        <AnimatedSection client:visible>
          <Persona5Card>
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2 gap-1">
              <h3 class="text-xl font-bold text-p5-white p5-hover-skew">
                {item.degree}
              </h3>
              <span class="text-sm font-mono text-p5-muted whitespace-nowrap">
                {item.period}
              </span>
            </div>
            <p class="text-p5-red font-bold mb-2">
              {item.institution}
            </p>
            {item.details && (
              <p class="text-p5-muted text-sm leading-relaxed">
                {item.details}
              </p>
            )}
          </Persona5Card>
        </AnimatedSection>
      ))}
    </div>
  </div>
</section>
