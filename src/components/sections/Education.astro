---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';
import AnimatedSection from '../../islands/AnimatedSection';

interface EducationItem {
  degree: string;
  institution: string;
  period: string;
  details?: string;
}

export interface Props {
  locale: Locale;
  items: EducationItem[];
}

const { locale, items } = Astro.props;
const t = useTranslations(locale);
---

<section id="education" class="py-24 sm:py-32 bg-gray-50/50 dark:bg-gray-900/30">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <AnimatedSection client:visible>
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        <span class="bg-gradient-to-r from-accent-400 to-blue-500 bg-clip-text text-transparent">
          {t('section.education')}
        </span>
      </h2>
      <div class="w-20 h-1 bg-accent-400 rounded-full mb-12"></div>
    </AnimatedSection>

    <div class="space-y-6">
      {items.map((item) => (
        <AnimatedSection client:visible>
          <div class="p-6 rounded-2xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 hover:border-accent-300 dark:hover:border-accent-700 hover:shadow-lg transition-all duration-300">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2 gap-1">
              <h3 class="text-xl font-bold text-gray-900 dark:text-white">
                {item.degree}
              </h3>
              <span class="text-sm font-mono text-gray-500 dark:text-gray-500 whitespace-nowrap">
                {item.period}
              </span>
            </div>
            <p class="text-accent-500 font-medium mb-2">
              {item.institution}
            </p>
            {item.details && (
              <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                {item.details}
              </p>
            )}
          </div>
        </AnimatedSection>
      ))}
    </div>
  </div>
</section>
