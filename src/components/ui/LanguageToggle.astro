---
import type { Locale } from '../../i18n/ui';
import { useTranslations } from '../../i18n/ui';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const targetLocale: Locale = locale === 'en' ? 'es' : 'en';
const targetPath = targetLocale === 'en' ? '/' : `/${targetLocale}/`;
---

<a
  href={targetPath}
  title={t('lang.label')}
  class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-semibold uppercase tracking-wider text-p5-muted border-2 border-p5-gray hover:border-p5-red hover:text-p5-red hover:shadow-[0_0_10px_rgba(229,57,53,0.3)] transition-all"
  aria-label={t('lang.label')}
>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
  </svg>
  <span>{t('lang.switch')}</span>
</a>
