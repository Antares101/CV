---
// ScrollToTop.astro - Scroll to top button with P5 styling
---

<button
  id="scroll-to-top"
  class="fixed bottom-6 right-6 z-50 w-12 h-12 bg-p5-red text-p5-white border-2 border-p5-red-dark hover:bg-p5-red-light hover:border-p5-red transition-all duration-200 opacity-0 translate-y-4 pointer-events-none p5-angular-border-sm shadow-lg hover:shadow-xl"
  aria-label="Scroll to top"
  title="Scroll to top"
>
  <svg class="w-5 h-5 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
  </svg>
</button>

<script is:inline>
  (function() {
    const button = document.getElementById('scroll-to-top');
    if (!button) return;

    // Show/hide button based on scroll position
    const toggleButton = () => {
      if (window.scrollY > 300) {
        button.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
        button.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
      } else {
        button.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
        button.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
      }
    };

    // Scroll to top with smooth animation
    const scrollToTop = () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    };

    // Event listeners
    window.addEventListener('scroll', toggleButton, { passive: true });
    button.addEventListener('click', scrollToTop);

    // Initial check
    toggleButton();
  })();
</script>

<style>
  /* P5 angular border for scroll-to-top button */
  .p5-angular-border-sm {
    clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 6px 100%, 0 calc(100% - 6px));
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    #scroll-to-top {
      transition: none !important;
    }
  }
</style>
