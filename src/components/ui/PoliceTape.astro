---
/**
 * PoliceTape.astro - Persona 5 style "CAUTION / PROHIBIDO" diagonal tape
 * Animated diagonal stripe that sits in the corner of the page.
 * Pure CSS, no external images. Accessible (aria-hidden, pointer-events-none).
 */
export interface Props {
  /** Position of the tape corner. Default: 'top-right' */
  position?: 'top-right' | 'top-left' | 'bottom-right' | 'bottom-left';
  /** Text displayed on the tape. Default: 'CAUTION' */
  text?: string;
  /** Additional CSS classes */
  class?: string;
}

const {
  position = 'top-right',
  text = 'CAUTION',
  class: className = '',
} = Astro.props;

const positionClasses: Record<string, string> = {
  'top-right': 'p5-tape-top-right',
  'top-left': 'p5-tape-top-left',
  'bottom-right': 'p5-tape-bottom-right',
  'bottom-left': 'p5-tape-bottom-left',
};
---

<div
  class:list={['p5-police-tape', positionClasses[position], className]}
  aria-hidden="true"
>
  <div class="p5-tape-stripe"></div>
  <div class="p5-tape-text">
    <span>{text}</span>
    <span>{text}</span>
    <span>{text}</span>
    <span>{text}</span>
    <span>{text}</span>
    <span>{text}</span>
    <span>{text}</span>
    <span>{text}</span>
    <span>{text}</span>
    <span>{text}</span>
    <span>{text}</span>
    <span>{text}</span>
  </div>
</div>

<style>
  .p5-police-tape {
    position: fixed;
    z-index: 20;
    pointer-events: none;
    overflow: hidden;
  }

  /* ===== TOP RIGHT ===== */
  .p5-tape-top-right {
    top: 0;
    right: 0;
    width: 280px;
    height: 280px;
  }

  @media (min-width: 641px) and (max-width: 1023px) {
    .p5-tape-top-right {
      width: 220px;
      height: 220px;
    }
  }

  @media (min-width: 1024px) {
    .p5-tape-top-right {
      width: 380px;
      height: 380px;
    }
  }

  .p5-tape-top-right .p5-tape-stripe {
    position: absolute;
    top: 50px;
    right: -100px;
    width: 500px;
    height: 56px;
    transform: rotate(45deg);
    background: repeating-linear-gradient(
      45deg,
      var(--p5-red) 0px,
      var(--p5-red) 40px,
      var(--p5-black) 40px,
      var(--p5-black) 80px
    );
    border-top: 2px solid var(--p5-white);
    border-bottom: 2px solid var(--p5-white);
    animation: p5TapeSlide 12s linear infinite;
  }

  @media (min-width: 641px) and (max-width: 1023px) {
    .p5-tape-top-right .p5-tape-stripe {
      top: 39px;
      right: -79px;
      width: 395px;
      height: 44px;
    }
  }

  @media (min-width: 1024px) {
    .p5-tape-top-right .p5-tape-stripe {
      top: 70px;
      right: -140px;
      width: 700px;
      height: 72px;
    }
  }

  .p5-tape-top-right .p5-tape-text {
    position: absolute;
    top: 50px;
    right: -100px;
    width: 500px;
    height: 56px;
    --tape-angle: 45deg;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Anton', 'Impact', sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--p5-white);
    white-space: nowrap;
    gap: 2rem;
    animation: p5TapeTextSlide 12s linear infinite;
  }

  @media (min-width: 641px) and (max-width: 1023px) {
    .p5-tape-top-right .p5-tape-text {
      top: 39px;
      right: -79px;
      width: 395px;
      height: 44px;
      font-size: 0.75rem;
      gap: 1.6rem;
    }
  }

  @media (min-width: 1024px) {
    .p5-tape-top-right .p5-tape-text {
      top: 70px;
      right: -140px;
      width: 700px;
      height: 72px;
      font-size: 1.1rem;
      gap: 2.5rem;
    }
  }

  /* ===== TOP LEFT ===== */
  .p5-tape-top-left {
    top: 0;
    left: 0;
    width: 280px;
    height: 280px;
  }

  .p5-tape-top-left .p5-tape-stripe {
    position: absolute;
    top: 40px;
    left: -80px;
    width: 400px;
    height: 48px;
    transform: rotate(-45deg);
    background: repeating-linear-gradient(
      90deg,
      var(--p5-red) 0px,
      var(--p5-red) 32px,
      var(--p5-black) 32px,
      var(--p5-black) 64px
    );
    border-top: 2px solid var(--p5-white);
    border-bottom: 2px solid var(--p5-white);
    animation: p5TapeSlide 12s linear infinite;
  }

  .p5-tape-top-left .p5-tape-text {
    position: absolute;
    top: 40px;
    left: -80px;
    width: 400px;
    height: 48px;
    --tape-angle: -45deg;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Anton', 'Impact', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--p5-white);
    white-space: nowrap;
    gap: 1.5rem;
    animation: p5TapeTextSlide 12s linear infinite;
  }

  /* ===== BOTTOM RIGHT ===== */
  .p5-tape-bottom-right {
    bottom: 0;
    right: 0;
    width: 280px;
    height: 280px;
  }

  .p5-tape-bottom-right .p5-tape-stripe {
    position: absolute;
    bottom: 40px;
    right: -80px;
    width: 400px;
    height: 48px;
    transform: rotate(-45deg);
    background: repeating-linear-gradient(
      90deg,
      var(--p5-red) 0px,
      var(--p5-red) 32px,
      var(--p5-black) 32px,
      var(--p5-black) 64px
    );
    border-top: 2px solid var(--p5-white);
    border-bottom: 2px solid var(--p5-white);
    animation: p5TapeSlide 12s linear infinite;
  }

  .p5-tape-bottom-right .p5-tape-text {
    position: absolute;
    bottom: 40px;
    right: -80px;
    width: 400px;
    height: 48px;
    --tape-angle: -45deg;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Anton', 'Impact', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--p5-white);
    white-space: nowrap;
    gap: 1.5rem;
    animation: p5TapeTextSlide 12s linear infinite;
  }

  /* ===== BOTTOM LEFT ===== */
  .p5-tape-bottom-left {
    bottom: 0;
    left: 0;
    width: 280px;
    height: 280px;
  }

  .p5-tape-bottom-left .p5-tape-stripe {
    position: absolute;
    bottom: 40px;
    left: -80px;
    width: 400px;
    height: 48px;
    transform: rotate(45deg);
    background: repeating-linear-gradient(
      90deg,
      var(--p5-red) 0px,
      var(--p5-red) 32px,
      var(--p5-black) 32px,
      var(--p5-black) 64px
    );
    border-top: 2px solid var(--p5-white);
    border-bottom: 2px solid var(--p5-white);
    animation: p5TapeSlide 12s linear infinite;
  }

  .p5-tape-bottom-left .p5-tape-text {
    position: absolute;
    bottom: 40px;
    left: -80px;
    width: 400px;
    height: 48px;
    --tape-angle: 45deg;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Anton', 'Impact', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--p5-white);
    white-space: nowrap;
    gap: 1.5rem;
    animation: p5TapeTextSlide 12s linear infinite;
  }

  /* ===== ANIMATIONS - seamless loop ===== */
  /* Background pattern repeats every 80px (40px red + 40px black).
     We shift by 160px = 2 full cycles for a perfect seamless loop. */
  @keyframes p5TapeSlide {
    0% { background-position: 0 0; }
    100% { background-position: 160px 0; }
  }

  @keyframes p5TapeTextSlide {
    0% { transform: rotate(var(--tape-angle)) translateX(0); }
    100% { transform: rotate(var(--tape-angle)) translateX(-50%); }
  }

  /* Light mode adjustments */
  :global(.light) .p5-tape-stripe {
    border-top-color: var(--p5-black);
    border-bottom-color: var(--p5-black);
  }

  :global(.light) .p5-tape-text {
    color: var(--p5-white);
  }

/* ===== RESPONSIVE: Mobile (≤640px) ===== */
  @media (max-width: 640px) {
    .p5-police-tape {
      width: 160px;
      height: 160px;
    }

    /* Top-right mobile */
    .p5-tape-top-right .p5-tape-stripe,
    .p5-tape-top-right .p5-tape-text {
      top: 28px;
      right: -55px;
      width: 280px;
      height: 32px;
    }
    .p5-tape-top-right .p5-tape-text {
      font-size: 0.55rem;
      gap: 0.8rem;
    }

    /* Top-left mobile */
    .p5-tape-top-left .p5-tape-stripe,
    .p5-tape-top-left .p5-tape-text {
      top: 22px;
      left: -45px;
      width: 230px;
      height: 28px;
    }
    .p5-tape-top-left .p5-tape-text {
      font-size: 0.5rem;
      gap: 0.8rem;
    }

    /* Bottom-right mobile */
    .p5-tape-bottom-right .p5-tape-stripe,
    .p5-tape-bottom-right .p5-tape-text {
      bottom: 22px;
      right: -45px;
      width: 230px;
      height: 28px;
    }
    .p5-tape-bottom-right .p5-tape-text {
      font-size: 0.5rem;
      gap: 0.8rem;
    }

    /* Bottom-left mobile */
    .p5-tape-bottom-left .p5-tape-stripe,
    .p5-tape-bottom-left .p5-tape-text {
      bottom: 22px;
      left: -45px;
      width: 230px;
      height: 28px;
    }
    .p5-tape-bottom-left .p5-tape-text {
      font-size: 0.5rem;
      gap: 0.8rem;
    }
  }

  /* ===== RESPONSIVE: Tablet (641px-1023px) ===== */
  @media (min-width: 641px) and (max-width: 1023px) {
    /* Top-left tablet */
    .p5-tape-top-left {
      width: 220px;
      height: 220px;
    }
    .p5-tape-top-left .p5-tape-stripe,
    .p5-tape-top-left .p5-tape-text {
      top: 31px;
      left: -63px;
      width: 315px;
      height: 38px;
    }
    .p5-tape-top-left .p5-tape-text {
      font-size: 0.65rem;
      gap: 1.2rem;
    }

    /* Bottom-right tablet */
    .p5-tape-bottom-right {
      width: 220px;
      height: 220px;
    }
    .p5-tape-bottom-right .p5-tape-stripe,
    .p5-tape-bottom-right .p5-tape-text {
      bottom: 31px;
      right: -63px;
      width: 315px;
      height: 38px;
    }
    .p5-tape-bottom-right .p5-tape-text {
      font-size: 0.65rem;
      gap: 1.2rem;
    }

    /* Bottom-left tablet */
    .p5-tape-bottom-left {
      width: 220px;
      height: 220px;
    }
    .p5-tape-bottom-left .p5-tape-stripe,
    .p5-tape-bottom-left .p5-tape-text {
      bottom: 31px;
      left: -63px;
      width: 315px;
      height: 38px;
    }
    .p5-tape-bottom-left .p5-tape-text {
      font-size: 0.65rem;
      gap: 1.2rem;
    }
  }
</style>
