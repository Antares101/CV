---
import type { Locale } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';
import LanguageToggle from '../components/ui/LanguageToggle.astro';
import PoliceTape from '../components/ui/PoliceTape.astro';
import ThemeToggle from '../islands/ThemeToggle';

export interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title = 'CV', description } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalURL = locale === 'en' ? `${base}/` : `${base}/${locale}/`;
const tapeText = locale === 'en' ? 'CAUTION' : 'PROHIBIDO';
---

<!DOCTYPE html>
<html lang={locale} class="scroll-smooth dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? `${title} — Personal CV`} />
    <link rel="canonical" href={`https://antares101.github.io/CV${canonicalURL}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Prevent theme flash - P5 defaults to DARK always, only respects explicit user toggle -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'light') {
          document.documentElement.classList.remove('dark');
          document.documentElement.classList.add('light');
        } else {
          document.documentElement.classList.add('dark');
          document.documentElement.classList.remove('light');
        }
      })();
    </script>

    <!-- Google Fonts: Anton + Inter + JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <title>{title} | Antares101</title>
  </head>
  <body class="antialiased">
    <!-- Skip link for accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-p5-red focus:text-white focus:rounded-none">
      Skip to main content
    </a>

    <!-- Police Tape - P5 caution tape decoration -->
    <PoliceTape position="top-right" text={tapeText} />

    <!-- Navigation - P5 aggressive angular style -->
    <nav class="fixed top-0 left-0 right-0 z-40 backdrop-blur-md border-b-2 border-p5-red/40 p5-nav-stripe">
      <!-- Red accent line above nav -->
      <div class="absolute top-0 left-0 right-0 h-[3px] bg-p5-red" aria-hidden="true"></div>
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo / Home - P5 angular style -->
          <a href={canonicalURL} class="font-display text-xl tracking-wider text-p5-white hover:text-p5-red transition-colors uppercase relative group">
            <span class="relative z-10">&lt;Antares101 /&gt;</span>
            <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-p5-red transition-all duration-300 group-hover:w-full" aria-hidden="true"></span>
          </a>

          <!-- Desktop Nav - P5 menu style (hidden on mobile) -->
          <div class="hidden md:flex items-center gap-1 text-sm font-semibold uppercase tracking-wider text-p5-muted p5-desktop-nav">
            <a href="#experience" class="p5-nav-link">{t('nav.experience')}</a>
            <a href="#skills" class="p5-nav-link">{t('nav.skills')}</a>
            <a href="#projects" class="p5-nav-link">{t('nav.projects')}</a>
            <a href="#contact" class="p5-nav-link">{t('nav.contact')}</a>
          </div>

          <!-- Right side controls -->
          <div class="flex items-center gap-3">
            <LanguageToggle locale={locale} />
            <ThemeToggle client:idle />
            <!-- Hamburger button - P5 diagonal style, mobile only -->
            <button
              id="p5-hamburger"
              class="md:hidden flex items-center justify-center w-12 h-12 text-p5-red hover:text-p5-red-light transition-colors"
              aria-label="Open menu"
              aria-expanded="false"
            >
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="3" y1="6" x2="21" y2="4" stroke="#e53935" stroke-width="2" stroke-linecap="square" />
                <line x1="3" y1="12" x2="21" y2="10" stroke="#e53935" stroke-width="2" stroke-linecap="square" />
                <line x1="3" y1="18" x2="21" y2="16" stroke="#e53935" stroke-width="2" stroke-linecap="square" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <!-- Mobile Menu Overlay - P5 fullscreen style -->
    <div id="p5-mobile-menu" class="fixed inset-0 z-50 bg-p5-black/95 backdrop-blur-md flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300" aria-hidden="true">
      <!-- P5 angular shard decorations -->
      <div class="absolute top-0 left-0 w-16 h-16 border-t-2 border-l-2 border-p5-red" aria-hidden="true"></div>
      <div class="absolute top-0 right-0 w-16 h-16 border-t-2 border-r-2 border-p5-red" aria-hidden="true"></div>
      <div class="absolute bottom-0 left-0 w-16 h-16 border-b-2 border-l-2 border-p5-red" aria-hidden="true"></div>
      <div class="absolute bottom-0 right-0 w-16 h-16 border-b-2 border-r-2 border-p5-red" aria-hidden="true"></div>

      <!-- Close button - P5 X style -->
      <button
        id="p5-menu-close"
        class="absolute top-5 right-5 w-10 h-10 flex items-center justify-center text-p5-red hover:text-p5-red-light transition-colors"
        aria-label="Close menu"
      >
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="4" y1="4" x2="24" y2="24" stroke="currentColor" stroke-width="2" stroke-linecap="square" />
          <line x1="24" y1="4" x2="4" y2="24" stroke="currentColor" stroke-width="2" stroke-linecap="square" />
        </svg>
      </button>

      <!-- Mobile nav links - P5 uppercase angular style -->
      <a href="#experience" class="p5-mobile-nav-link font-display text-3xl uppercase tracking-wider text-p5-white hover:text-p5-red transition-colors">{t('nav.experience')}</a>
      <a href="#skills" class="p5-mobile-nav-link font-display text-3xl uppercase tracking-wider text-p5-white hover:text-p5-red transition-colors">{t('nav.skills')}</a>
      <a href="#projects" class="p5-mobile-nav-link font-display text-3xl uppercase tracking-wider text-p5-white hover:text-p5-red transition-colors">{t('nav.projects')}</a>
      <a href="#contact" class="p5-mobile-nav-link font-display text-3xl uppercase tracking-wider text-p5-white hover:text-p5-red transition-colors">{t('nav.contact')}</a>

      <!-- Red accent line below links -->
      <div class="w-24 h-[3px] bg-p5-red mt-4" aria-hidden="true"></div>
    </div>

    <main id="main-content" class="relative">
      <!-- P5 star field background overlay -->
      <div class="p5-stars" aria-hidden="true"></div>
      <div class="p5-stars-png" aria-hidden="true">
        <div class="p5-star-icon"></div>
        <div class="p5-star-icon"></div>
        <div class="p5-star-icon"></div>
        <div class="p5-star-icon"></div>
        <div class="p5-star-icon"></div>
        <div class="p5-star-icon"></div>
        <div class="p5-star-icon"></div>
        <div class="p5-star-icon"></div>
        <div class="p5-star-icon"></div>
        <div class="p5-star-icon"></div>
      </div>
      <div class="relative z-10">
        <slot />
      </div>
    </main>

    <!-- Footer - P5 style -->
    <footer class="relative border-t-2 border-p5-red/40 py-10 text-center overflow-hidden">
      <!-- Decorative shard corners -->
      <div class="p5-shard-corner-tl" aria-hidden="true"></div>
      <div class="p5-shard-corner-br" aria-hidden="true"></div>
      <!-- Red accent line -->
      <div class="absolute top-0 left-0 right-0 h-[3px] bg-p5-red" aria-hidden="true"></div>
      <div class="relative z-10 max-w-5xl mx-auto px-4">
        <p class="mb-1 text-p5-muted font-mono text-sm">
          <span class="text-p5-red">&gt;</span> {t('footer.made')} <span class="text-p5-red">&lt;</span>
        </p>
        <p class="text-p5-muted/60 text-xs font-mono">&copy; {new Date().getFullYear()} Antares101. All rights reserved.</p>
      </div>
    </footer>
  <!-- Mobile menu toggle logic -->
    <script is:inline>
      (function() {
        const hamburger = document.getElementById('p5-hamburger');
        const menu = document.getElementById('p5-mobile-menu');
        const closeBtn = document.getElementById('p5-menu-close');
        const mobileLinks = menu ? menu.querySelectorAll('.p5-mobile-nav-link') : [];

        function openMenu() {
          if (!menu) return;
          menu.classList.remove('opacity-0', 'pointer-events-none');
          menu.classList.add('opacity-100', 'pointer-events-auto');
          menu.setAttribute('aria-hidden', 'false');
          if (hamburger) hamburger.setAttribute('aria-expanded', 'true');
          document.body.style.overflow = 'hidden';
        }

        function closeMenu() {
          if (!menu) return;
          menu.classList.remove('opacity-100', 'pointer-events-auto');
          menu.classList.add('opacity-0', 'pointer-events-none');
          menu.setAttribute('aria-hidden', 'true');
          if (hamburger) hamburger.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        }

        if (hamburger) hamburger.addEventListener('click', openMenu);
        if (closeBtn) closeBtn.addEventListener('click', closeMenu);

        // Close on link click and scroll to section
        mobileLinks.forEach(function(link) {
          link.addEventListener('click', function() {
            closeMenu();
          });
        });

        // Close on Escape key
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') closeMenu();
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import url('../styles/print.css');
  @import url('../styles/persona5.css');

  html {
    background-color: #0a0a0a;
  }

  body {
    min-height: 100vh;
  }

  .light body,
  body.light {
    background-color: #f5f5f5;
    color: #0a0a0a;
  }

  /* Fix: ensure desktop nav is hidden on mobile even if other CSS overrides display */
  @media (max-width: 767px) {
    .p5-desktop-nav {
      display: none !important;
    }
  }

  /* P5 mobile nav link angular hover effect */
  .p5-mobile-nav-link {
    position: relative;
    padding: 0.5rem 1.5rem;
    clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 6px 100%, 0 calc(100% - 6px));
    transition: all 0.15s ease-out;
  }

  .p5-mobile-nav-link:hover {
    background: var(--p5-red);
    color: var(--p5-white);
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
  }

  /* Light mode mobile nav */
  html.light .p5-mobile-nav-link:hover {
    color: var(--p5-white);
  }
</style>
