---
import type { Locale } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';
import LanguageToggle from '../components/ui/LanguageToggle.astro';
import ThemeToggle from '../islands/ThemeToggle';

export interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title = 'CV', description } = Astro.props;
const t = useTranslations(locale);
const canonicalURL = locale === 'en' ? '/' : `/${locale}/`;
---

<!DOCTYPE html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? `${title} — Personal CV`} />
    <link rel="canonical" href={`https://antares101.github.io/CV${canonicalURL}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Inter + JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Prevent theme flash on load -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (theme === 'dark' || (!theme && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <title>{title} | Antares101</title>
  </head>
  <body class="bg-white text-gray-900 dark:bg-slate-950 dark:text-gray-100 transition-colors duration-300 antialiased">
    <!-- Skip link for accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent-500 focus:text-white focus:rounded-lg">
      Skip to main content
    </a>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-40 backdrop-blur-md bg-white/70 dark:bg-slate-950/70 border-b border-gray-200/50 dark:border-gray-800/50">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo / Home -->
          <a href={canonicalURL} class="font-bold text-lg tracking-tight hover:text-accent-500 transition-colors">
            &lt;Antares101 /&gt;
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600 dark:text-gray-400">
            <a href="#experience" class="hover:text-accent-500 dark:hover:text-accent-400 transition-colors">{t('nav.experience')}</a>
            <a href="#skills" class="hover:text-accent-500 dark:hover:text-accent-400 transition-colors">{t('nav.skills')}</a>
            <a href="#projects" class="hover:text-accent-500 dark:hover:text-accent-400 transition-colors">{t('nav.projects')}</a>
            <a href="#education" class="hover:text-accent-500 dark:hover:text-accent-400 transition-colors">{t('nav.education')}</a>
            <a href="#contact" class="hover:text-accent-500 dark:hover:text-accent-400 transition-colors">{t('nav.contact')}</a>
          </div>

          <!-- Right side controls -->
          <div class="flex items-center gap-3">
            <LanguageToggle locale={locale} />
            <ThemeToggle client:idle />
          </div>
        </div>
      </div>
    </nav>

    <main id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 dark:border-gray-800 py-8 text-center text-sm text-gray-500 dark:text-gray-500">
      <p class="mb-1">{t('footer.made')}</p>
      <p>&copy; {new Date().getFullYear()} Antares101. All rights reserved.</p>
    </footer>
  </body>
</html>

<!-- Inline global styles for print -->
<style is:global>
  @import url('../styles/print.css');
</style>
